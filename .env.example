# Docker Compose project and container name prefix
PROJECT_NAME=bitrix-local

# Local HTTPS domain (must match hosts file and certificate file name)
DOMAIN=bitrix.local

HTTP_PORT=80
HTTPS_PORT=443
TIMEZONE=Europe/Moscow

# Pinned nginx image — do not bump without testing
NGINX_IMAGE=nginx:1.27.4-bookworm

# PHP-FPM image tag and optional extra extensions (space-separated)
# mbstring is always installed in the base image (required by Bitrix)
# Example: imagick redis xdebug
PHP_VERSION=8.3
PHP_EXTRA_EXTENSIONS=

# Linux/macOS: set to your user to avoid permission issues in www/
UID=1000
GID=1000
XDEBUG_MODE=off

# Pinned MySQL image — do not bump to 8.4/9.0 without testing Bitrix compatibility
MYSQL_IMAGE=mysql:8.0.36
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=bitrix
MYSQL_USER=bitrix
MYSQL_PASSWORD=bitrix
